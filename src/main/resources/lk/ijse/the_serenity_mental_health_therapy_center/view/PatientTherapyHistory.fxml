<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="462.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.PatientTherapyHistoryController">
   <children>
      <VBox prefHeight="462.0" prefWidth="874.0">
         <children>
            <HBox prefHeight="54.0" prefWidth="874.0">
               <children>
                  <TextField fx:id="txtSearch" prefHeight="26.0" prefWidth="242.0" promptText="Search Patient by ID or name">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #2C7A7B;" text="Search" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #2C7A7B;" text="Refresh" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <TableView fx:id="tblPatients" onMouseClicked="#handlePatientTableClick" prefHeight="170.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="95.20001065731049" text="ID" />
                  <TableColumn fx:id="colName" prefWidth="204.00000762939453" text="Full Name" />
                  <TableColumn fx:id="colEmail" prefWidth="199.20001220703125" text="Email" />
                  <TableColumn fx:id="colAddress" prefWidth="201.60000610351562" text="Address" />
                  <TableColumn fx:id="colPhone" prefWidth="174.39996337890625" text="Phone" />
               </columns>
            </TableView>
            <Label prefHeight="30.0" prefWidth="874.0" style="-fx-background-color: #2C7A7B;" text="Therapy History" textFill="WHITE">
               <font>
                  <Font name="Cambria Math" size="14.0" />
               </font>
               <padding>
                  <Insets left="10.0" />
               </padding>
            </Label>
            <TableView fx:id="tblHistory" prefHeight="196.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;">
               <columns>
                  <TableColumn fx:id="colHistDate" prefWidth="120.0" text="Date" />
                  <TableColumn fx:id="colHistSession" prefWidth="220.0" text="Program Name" />
                  <TableColumn fx:id="colHistTherapist" prefWidth="220.0" text="Therapist Name" />
                  <TableColumn fx:id="colHistStatus" prefWidth="120.0" text="Status" />
                  <TableColumn fx:id="colHistNotes" prefWidth="192.0" text="Notes" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
