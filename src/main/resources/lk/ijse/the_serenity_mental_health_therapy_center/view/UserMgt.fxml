<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="462.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.UserMgtController">
   <children>
      <VBox prefHeight="462.0" prefWidth="874.0">
         <children>
            <HBox prefHeight="57.0" prefWidth="874.0">
               <children>
                  <TextField fx:id="txtSearch" prefHeight="26.0" prefWidth="242.0" promptText="Search User by ID or Username">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #2C7A7B;" text="Search" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #2C7A7B;" text="Refresh" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btnAddUser" mnemonicParsing="false" onAction="#handleAddUser" prefHeight="27.0" prefWidth="120.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="+ Add User" textAlignment="CENTER" textFill="#2c7a7b">
                     <HBox.margin>
                        <Insets left="150.0" top="8.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnEditUser" mnemonicParsing="false" onAction="#handleEditUser" prefHeight="27.0" prefWidth="60.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="Edit" textAlignment="CENTER" textFill="#2c7a7b">
                     <HBox.margin>
                        <Insets left="10.0" top="8.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnToggleStatus" mnemonicParsing="false" onAction="#handleToggleStatus" prefHeight="27.0" prefWidth="130.0" style="-fx-background-color: #eee8a9; -fx-border-color: #cc1c1c; -fx-border-width: 2;" text="Activate/Deactivate" textAlignment="CENTER" textFill="#bf1313">
                     <HBox.margin>
                        <Insets left="10.0" top="8.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <TableView fx:id="tblUsers" prefHeight="380.0" prefWidth="854.0" style="-fx-background-color: #f0f4f8;">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                  <TableColumn fx:id="colUsername" prefWidth="140.0" text="Username" />
                  <TableColumn fx:id="colName" prefWidth="200.0" text="Full Name" />
                  <TableColumn fx:id="colEmail" prefWidth="220.0" text="Email" />
                  <TableColumn fx:id="colRole" prefWidth="120.0" text="Role" />
                  <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
               </columns>
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" />
               </VBox.margin>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
