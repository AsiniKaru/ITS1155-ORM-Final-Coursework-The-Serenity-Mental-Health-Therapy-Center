<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="407.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.RevenueReportController">
   <children>
      <VBox prefHeight="407.0" prefWidth="874.0">
         <children>
            <HBox prefHeight="46.0" prefWidth="874.0">
               <children>
                  <Label prefHeight="23.0" prefWidth="52.0" text="From : ">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dpFrom" prefHeight="26.0" prefWidth="145.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </DatePicker>
                  <Label prefHeight="23.0" prefWidth="37.0" text="To :">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dpTo" prefHeight="26.0" prefWidth="152.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </DatePicker>
                  <Button fx:id="btnGenerate" mnemonicParsing="false" onAction="#handleGenerateReport" prefHeight="26.0" prefWidth="120.0" style="-fx-background-color: #2c7a7b;" text="Generate" textAlignment="CENTER" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnReset" mnemonicParsing="false" onAction="#handleReset" prefHeight="26.0" prefWidth="60.0" style="-fx-background-color: #2c7a7b;" text="Reset" textAlignment="CENTER" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnPrint" mnemonicParsing="false" onAction="#handlePrintReport" prefHeight="26.0" prefWidth="60.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2c7a7b; -fx-border-width: 1;" text="Print" textAlignment="CENTER" textFill="#2c7a7b">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Label fx:id="lblTotalRevenue" prefHeight="30.0" prefWidth="244.0" text="Total Revenue: Rs. 0.00" textFill="#2c7a7b">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="30.0" top="8.0" />
                     </HBox.margin>
                  </Label>
               </children>
            </HBox>
            <TableView fx:id="tblRevenue" prefHeight="361.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="Payment ID" />
                <TableColumn fx:id="colInvoice" prefWidth="120.0" text="Invoice No" />
                  <TableColumn fx:id="colPatient" prefWidth="200.0" text="Patient Name" />
                  <TableColumn fx:id="colDate" prefWidth="150.0" text="Payment Date" />
                  <TableColumn fx:id="colMethod" prefWidth="120.0" text="Payment Method" />
                  <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                  <TableColumn fx:id="colAmount" prefWidth="100.0" text="Amount" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
