<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="407.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.AdminSessionReportController">
   <children>
      <VBox prefHeight="407.0" prefWidth="874.0">
         <children>
            <HBox prefHeight="46.0" prefWidth="874.0">
               <children>
                  <Label prefHeight="23.0" prefWidth="45.0" text="From : ">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dpFrom" prefHeight="26.0" prefWidth="126.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </DatePicker>
                  <Label prefHeight="23.0" prefWidth="25.0" text="To :">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dpTo" prefHeight="26.0" prefWidth="130.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </DatePicker>
                  <Label prefHeight="23.0" prefWidth="55.0" text="Status :">
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                  </Label>
                  <ChoiceBox fx:id="choiceStatus" prefWidth="120.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </ChoiceBox>
                  <Button fx:id="btnGenerate" mnemonicParsing="false" onAction="#handleGenerateReport" prefHeight="26.0" prefWidth="120.0" style="-fx-background-color: #2c7a7b;" text="Generate" textAlignment="CENTER" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnReset" mnemonicParsing="false" onAction="#handleReset" prefHeight="26.0" prefWidth="60.0" style="-fx-background-color: #2c7a7b;" text="Reset" textAlignment="CENTER" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnPrint" mnemonicParsing="false" onAction="#handlePrintReport" prefHeight="26.0" prefWidth="60.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2c7a7b; -fx-border-width: 1;" text="Print" textAlignment="CENTER" textFill="#2c7a7b">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <TableView fx:id="tblSessions" prefHeight="361.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colPatient" prefWidth="150.0" text="Patient" />
                  <TableColumn fx:id="colTherapist" prefWidth="150.0" text="Therapist" />
                  <TableColumn fx:id="colProgram" prefWidth="150.0" text="Program" />
                  <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
                  <TableColumn fx:id="colTime" prefWidth="80.0" text="Time" />
                  <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
                  <TableColumn fx:id="colNotes" prefWidth="90.0" text="Notes" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
