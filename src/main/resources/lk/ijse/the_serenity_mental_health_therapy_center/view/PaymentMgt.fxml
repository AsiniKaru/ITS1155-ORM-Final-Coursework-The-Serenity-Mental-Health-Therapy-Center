<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="462.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.PaymentMgtController">
   <children>
      <VBox prefHeight="462.0" prefWidth="874.0">
         <children>
            <HBox prefHeight="46.0" prefWidth="874.0">
               <children>
                  <Label prefHeight="23.0" prefWidth="45.0" text="From : ">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dpFrom" prefHeight="26.0" prefWidth="120.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </DatePicker>
                  <Label prefHeight="23.0" prefWidth="25.0" text="To :">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dpTo" prefHeight="26.0" prefWidth="120.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </DatePicker>
                  <Label prefHeight="23.0" prefWidth="45.0" text="Status :">
                     <font>
                        <Font name="Calisto MT" size="14.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                  </Label>
                  <ChoiceBox fx:id="cbStatus" prefHeight="26.0" prefWidth="90.0">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </ChoiceBox>
                  <Button mnemonicParsing="false" onAction="#handleSearch" prefHeight="26.0" prefWidth="60.0" style="-fx-background-color: #2c7a7b;" text="Search" textAlignment="CENTER" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleReset" prefHeight="26.0" prefWidth="55.0" style="-fx-background-color: #2c7a7b;" text="Reset" textAlignment="CENTER" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleViewInvoice" prefHeight="27.0" prefWidth="100.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="View Invoice" textAlignment="CENTER" textFill="#2c7a7b">
                     <font>
                        <Font name="System Bold" size="11.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="20.0" top="8.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleRecordPayment" prefHeight="27.0" prefWidth="120.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="+ Record Payment" textAlignment="CENTER" textFill="#2c7a7b">
                     <font>
                        <Font name="System Bold" size="11.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="10.0" top="8.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <Pane prefHeight="418.0" prefWidth="874.0">
               <children>
                  <TableView fx:id="tblPayments" layoutX="10.0" layoutY="10.0" prefHeight="398.0" prefWidth="854.0" style="-fx-background-color: #f0f4f8;">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="colInvoice" prefWidth="120.0" text="Invoice #" />
                      <TableColumn fx:id="colPatient" prefWidth="190.0" text="Patient" />
                      <TableColumn fx:id="colAmount" prefWidth="110.0" text="Amount (LKR)" />
                      <TableColumn fx:id="colDate" prefWidth="150.0" text="Date &amp; Time" />
                      <TableColumn fx:id="colMethod" prefWidth="100.0" text="Method" />
                      <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                    </columns>
                  </TableView>
               </children>
            </Pane>
         </children>
      </VBox>
   </children>
</AnchorPane>
