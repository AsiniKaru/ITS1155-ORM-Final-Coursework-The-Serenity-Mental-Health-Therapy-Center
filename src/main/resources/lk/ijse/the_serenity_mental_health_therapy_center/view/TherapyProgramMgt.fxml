<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="462.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.TherapyProgramController">
   <children>
      <VBox prefHeight="462.0" prefWidth="874.0">
         <children>
            <HBox prefHeight="74.0" prefWidth="874.0">
               <children>
                  <TextField fx:id="txtSearch" onAction="#handleSearch" prefHeight="26.0" prefWidth="242.0" promptText="Search Therapy Program by code or name">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #2C7A7B;" text="Search" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #2C7A7B;" text="Refresh" textFill="WHITE">
                     <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleAddProgram" prefHeight="27.0" prefWidth="168.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="+ Add Program" textAlignment="CENTER" textFill="#2c7a7b">
                     <HBox.margin>
                        <Insets left="180.0" top="8.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleEditProgram" prefHeight="27.0" prefWidth="49.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="Edit" textAlignment="CENTER" textFill="#2c7a7b">
                     <HBox.margin>
                        <Insets left="10.0" top="8.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleDeleteProgram" prefHeight="27.0" prefWidth="70.0" style="-fx-background-color: #eee8a9; -fx-border-color: #cc1c1c; -fx-border-width: 2;" text="Deactive" textAlignment="CENTER" textFill="#c70404">
                     <HBox.margin>
                        <Insets left="10.0" top="8.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <TableView fx:id="tblPrograms" prefHeight="416.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;">
               <columns>
                  <TableColumn fx:id="colCode" prefWidth="75.0" text="Code" />
                  <TableColumn fx:id="colName" prefWidth="240.8000259399414" text="Program Name" />
                  <TableColumn fx:id="colDuration" minWidth="0.0" prefWidth="147.20001220703125" text="Duration" />
                  <TableColumn fx:id="colFee" prefWidth="163.19992065429688" text="Fee (LKR)" />
                  <TableColumn fx:id="colDescription" prefWidth="248.800048828125" text="Description" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
