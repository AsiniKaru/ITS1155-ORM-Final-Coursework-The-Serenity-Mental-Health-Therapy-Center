<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="462.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.the_serenity_mental_health_therapy_center.controller.SessionMgtController">
    <children>
        <VBox prefHeight="462.0" prefWidth="874.0">
            <children>
                <HBox prefHeight="55.0" prefWidth="874.0">
                    <children>
                        <TextField fx:id="txtSearch" onAction="#handleSearch" prefHeight="26.0" prefWidth="242.0" promptText="Search Session by ID or name">
                            <HBox.margin>
                                <Insets left="10.0" top="10.0" />
                            </HBox.margin>
                        </TextField>
                        <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #2C7A7B;" text="Search" textFill="WHITE">
                            <HBox.margin>
                                <Insets left="5.0" top="10.0" />
                            </HBox.margin>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #2C7A7B;" text="Refresh" textFill="WHITE">
                            <HBox.margin>
                                <Insets left="5.0" top="10.0" />
                            </HBox.margin>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleBookSession" prefHeight="27.0" prefWidth="168.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="Book Session" textAlignment="CENTER" textFill="#2c7a7b">
                            <HBox.margin>
                                <Insets left="150.0" top="8.0" />
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleCompleteSession" prefHeight="30.0" prefWidth="79.0" style="-fx-background-color: #eee8a9; -fx-border-color: #2C7A7B; -fx-border-width: 2;" text="Complete" textAlignment="CENTER" textFill="#2c7a7b">
                            <HBox.margin>
                                <Insets left="10.0" top="8.0" />
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleCancelSession" prefHeight="27.0" prefWidth="70.0" style="-fx-background-color: #eee8a9; -fx-border-color: #cc1c1c; -fx-border-width: 2;" text="Cancel" textAlignment="CENTER" textFill="#bf1313">
                            <HBox.margin>
                                <Insets left="10.0" top="8.0" />
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
                <TableView fx:id="tblSessions" prefHeight="416.0" prefWidth="874.0" style="-fx-background-color: #f0f4f8;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colPatient" prefWidth="170.0" text="Patient" />
                        <TableColumn fx:id="colTherapist" minWidth="0.0" prefWidth="140.0" text="Therapist" />
                        <TableColumn fx:id="colProgram" prefWidth="150.0" text="Program" />
                        <TableColumn fx:id="colSchedule" prefWidth="150.0" text="Schedule " />
                        <TableColumn fx:id="colUpfront" prefWidth="100.0" text="Upfront LKR" />
                        <TableColumn fx:id="colStatus" prefWidth="84.0" text="Status" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
