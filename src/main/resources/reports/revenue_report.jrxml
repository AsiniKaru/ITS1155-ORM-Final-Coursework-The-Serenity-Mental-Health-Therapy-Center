<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="revenue_report"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="b7c6d5e4-f3a2-b1c0-d9e8-7f6a5b4c3d2e">

    <parameter name="startDate" class="java.lang.String"/>
    <parameter name="endDate" class="java.lang.String"/>
    <parameter name="totalRevenue" class="java.lang.String"/>

    <field name="paymentId" class="java.lang.String"/>
    <field name="invoiceNumber" class="java.lang.String"/>
    <field name="patientName" class="java.lang.String"/>
    <field name="paymentDate" class="java.lang.String"/>
    <field name="paymentMethod" class="java.lang.String"/>
    <field name="paymentStatus" class="java.lang.String"/>
    <field name="amount" class="java.lang.Double"/>

    <title>
        <band height="120">
            <!-- Header Teal Rectangle -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="75" forecolor="#2C7A7B" backcolor="#2C7A7B"/>
            </rectangle>
            <staticText>
                <reportElement x="10" y="10" width="535" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font fontName="SansSerif" size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[THE SERENITY MENTAL HEALTH THERAPY CENTER]]></text>
            </staticText>
            <staticText>
                <reportElement x="10" y="40" width="535" height="20" forecolor="#FFF6DE"/>
                <textElement textAlignment="Center">
                    <font fontName="SansSerif" size="12" isItalic="true"/>
                </textElement>
                <text><![CDATA[Revenue & Financial Report]]></text>
            </staticText>

            <!-- Date range parameters -->
            <staticText>
                <reportElement x="5" y="90" width="75" height="20" forecolor="#333333"/>
                <textElement>
                    <font fontName="SansSerif" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Date Range:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="85" y="90" width="300" height="20" forecolor="#333333"/>
                <textElement>
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{startDate} + "  to  " + $P{endDate}]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="115" width="555" height="1" forecolor="#2C7A7B"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <!-- Header Background -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="25" forecolor="#2C7A7B" backcolor="#2C7A7B"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="5" width="80" height="15" forecolor="#FFFFFF"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Payment ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="90" y="5" width="80" height="15" forecolor="#FFFFFF"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Invoice #]]></text>
            </staticText>
            <staticText>
                <reportElement x="175" y="5" width="130" height="15" forecolor="#FFFFFF"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Patient Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="5" width="90" height="15" forecolor="#FFFFFF"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="405" y="5" width="50" height="15" forecolor="#FFFFFF"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Method]]></text>
            </staticText>
            <staticText>
                <reportElement x="460" y="5" width="45" height="15" forecolor="#FFFFFF"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
            <staticText>
                <reportElement x="510" y="5" width="40" height="15" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="5" y="3" width="80" height="15"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{paymentId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="90" y="3" width="80" height="15"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{invoiceNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="175" y="3" width="130" height="15"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{patientName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="310" y="3" width="90" height="15"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{paymentDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="405" y="3" width="50" height="15"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{paymentMethod}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="460" y="3" width="45" height="15"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{paymentStatus}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="510" y="3" width="40" height="15"/>
                <textElement textAlignment="Right">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="18" width="555" height="1" forecolor="#E0E0E0"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="60">
            <line>
                <reportElement x="0" y="5" width="555" height="1" forecolor="#2C7A7B"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>
            
            <rectangle>
                <reportElement x="320" y="10" width="235" height="35" forecolor="#2C7A7B" backcolor="#FFF6DE"/>
            </rectangle>
            
            <staticText>
                <reportElement x="330" y="20" width="100" height="20" forecolor="#2C7A7B"/>
                <textElement>
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Revenue:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="435" y="20" width="110" height="20" forecolor="#2C7A7B"/>
                <textElement textAlignment="Right">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalRevenue}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
